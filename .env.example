# 🔑 BIẾN MÔI TRƯỜNG MẪU (Dành cho nhóm phát triển)
# Copy nội dung này sang file `.env` và điền thông tin thực tế của bạn.

# 1. Kết nối Cơ sở dữ liệu (PostgreSQL)
# Cấu trúc: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quanlychitieu_db?schema=public"

# 2. Cấu hình Xác thực (Next Auth v5)
# Chạy lệnh: `openssl rand -base64 32` để tạo Secret riêng cho mình
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Bắt buộc đặt là "true" để NextAuth hoạt động trên Local hoặc Vercel
AUTH_TRUST_HOST="true"

# 3. Trí tuệ nhân tạo (Google Gemini)
# Lấy API Key miễn phí tại: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"
